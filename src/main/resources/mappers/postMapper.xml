<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="com.tuttigram.post.dao.PostDAO">


		<!-- 글쓰기 -->
	
	<insert id="insertPost" parameterType="map">
	
		INSERT INTO
			`post`
		(
			`userId`
			, `content`
			, `imagePath`
			, `createdAt`
			, `updatedAt`
		)
		
		VALUES
		(
			#{userId}
			, #{content}
			, #{imagePath}
			, now()
			, now()
		)
	
	</insert>
	
	
	
		<!-- 게시물 업로드 -->
		
	<select id="selectPostList" parameterType="int"
		resultType="com.tuttigram.post.model.Post">
	
	SELECT
		`id`
		, `userId`
		, `content`
		, `imagePath`
		, `createdAt`
		, `updatedAt`
	 
	FROM
		`post`
	
	ORDER BY
		`id` DESC
	
	</select>



</mapper>